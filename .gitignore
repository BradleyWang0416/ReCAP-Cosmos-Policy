*.mp4
*.hdf5
*.distcp

# ── Python build / cache ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
*.egg
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
/build
ckpt/*

# ── Editor / IDE / OS junk ─────────────────────────────────────────────────
.idea/
.vscode/
.DS_Store
.cuda-name

# ── Virtual env / tooling ──────────────────────────────────────────────────
.venv/
.claude/
bin/
uv-cache/
node_modules/

# ── Bundled subrepo (kept out of this repo's commits) ──────────────────────
robocasa-cosmos-policy/

# ── Training: experiment tracking / logs / checkpoints / outputs ───────────
# These are all generated by the trainer and can run to many GB per run.
# (Note: `logging/` is intentionally NOT here — that directory holds tracked
#  dev memos / results tables, not trainer logs.)
wandb/
**/wandb/
rollouts/
outputs/
**/checkpoints/
**/_evallogs/

# Per-experiment log dirs. Cover every variant we've used so far via globs
# instead of listing them one-by-one. `logs*/` catches both `logs/`,
# `logs_parallel/`, and numeric suffixes like `logs2/`, `logs3/`.
logs*/
**/logs*/
**/_logs/
**/log_*/

# Eval rollout dirs (ENV_EVAL-*/ tree under each experiment's logs/).
**/ENV_EVAL-*/

# Cosmos attention-dump style viz directories (locally generated by
# analysis_tools/ scripts; same shape as /mnt/ddn/tmp/attn_dump).
**/_viz/
**/_viz_*/
attn_dump/
**/attn_dump/

# Per-script visualization output dirs.
visualize_*_output/
overlay_*/
render_outputs/
analysis_outputs/

# Per-task home pose JSON backups (the live home_poses/ stays tracked).
home_poses__backup_*/
*__backup_*/

# ── Loose top-level artifacts that scripts drop in cwd ─────────────────────
# Render previews, hand-debug PNGs, intermediate npz / pt / safetensors. The
# live dataset/config files live under tracked dirs (cosmos_policy/...), so
# glob-banning these at the repo root is safe.
/*.mp4
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.svg
/*.npz
/*.npy
/*.pt
/*.safetensors
/*.pkl

# Generic per-process log files (e.g. /tmp redirect copies left in repo root).
/*.log
*_run.log
*.tmp
*.bak

# ── Local-only env / secrets ───────────────────────────────────────────────
.env
.env.local
.env.*.local
